{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": "allow",
  "mcp": {
    "unitytest": {
      "type": "remote",
      "url": "http://127.0.0.1:{{PORT}}/mcp",
      "enabled": true,
      "timeout": 600000000
    }
  },
  "provider": {
    "ucagent": {
      "options": {
        "baseURL": "{{OPENAI_API_BASE}}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "{{OPENAI_MODEL}}": {
          "name": "{{OPENAI_MODEL}}"
        }
      }
    }
  }{% if OPENAI_API_BASE %}{% if OPENAI_MODEL %},
  "model": "ucagent/{{OPENAI_MODEL}}"
  {% endif %}{% endif %}
}
